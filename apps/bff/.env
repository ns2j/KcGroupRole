# .env

# Server Settings
PORT=8020
SESSION_SECRET=super-secret-key-change-this-in-production
# Base Path
BFF_BASE_PATH=/bff

# Keycloak Settings
KEYCLOAK_CLIENT_ID=example-client
KEYCLOAK_CLIENT_SECRET=ciVmu25YBEtVsldMWb5oMc0oB3ngAFLL
KEYCLOAK_ISSUER=http://172.26.221.85:8080/realms/example

# Settings for mobile (Flutter)
FLUTTER_CALLBACK_URL=com.example.flutterauthapp://callback

# Base URL for the BFF itself (10.0.2.2 for emulator testing, localhost for web development)
#BFF_BASE_URL=http://10.0.2.2:8020
#BFF_BASE_URL=http://localhost:8020
BFF_BASE_URL=http://172.16.2.211:8020

# CORS settings (multiple origins can be specified separated by commas)
ALLOWED_ORIGINS=http://172.16.2.211:3000,http://localhost:3000

# Spring Boot Backend API server URL
SPRING_BACKEND_URL=http://172.16.2.211:8010/backend

# --- Cookie (Session Sharing) Settings ---
# Settings for sharing cookies across domains in production environments, etc.

# 1. Root domain sharing (e.g., .example.com)
# To share across subdomains, specify with a leading dot. Leave empty for local (localhost).
COOKIE_DOMAIN=

# 2. Cross-domain sharing (sharing between completely different domains)
# For cross-domain, COOKIE_SAME_SITE=none and COOKIE_SECURE=true are mandatory.
# * COOKIE_SECURE=true only works with HTTPS communication.
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
